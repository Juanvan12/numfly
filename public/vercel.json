{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/en", "destination": "/", "permanent": true },
    { "source": "/en/:path*", "destination": "/:path*", "permanent": true }
  ],
"rewrites": [
    { "source": "/nl/vrienden", "destination": "/friends" },
    { "source": "/es/amigos", "destination": "/friends" },
    
    { "source": "/nl/statistieken", "destination": "/stats" },
    { "source": "/es/estadisticas", "destination": "/stats" },
    
    { "source": "/nl/klassement", "destination": "/leaderboard" },
    { "source": "/es/clasificacion", "destination": "/leaderboard" },

    { "source": "/nl/prestaties", "destination": "/achievements" },
    { "source": "/es/logros", "destination": "/achievements" },

    { "source": "/nl/tips", "destination": "/tips" },
    { "source": "/es/consejos", "destination": "/tips" },

    { "source": "/nl/campagne", "destination": "/campaign" },
    { "source": "/es/campana", "destination": "/campaign" },

    { "source": "/nl/dagelijks", "destination": "/daily" },
    { "source": "/es/diario", "destination": "/daily" },

    { "source": "/nl/bliksem", "destination": "/lightning" },
    { "source": "/es/rayo", "destination": "/lightning" },

    { "source": "/nl/snelheid", "destination": "/speed" },
    { "source": "/es/velocidad", "destination": "/speed" },

    { "source": "/nl/oefenen", "destination": "/practice" },
    { "source": "/es/practica", "destination": "/practice" },

    { "source": "/nl/1v1", "destination": "/1v1" },
    { "source": "/es/1v1", "destination": "/1v1" },

    { "source": "/nl/hoofdrekenen-oefenen", "destination": "/how-to-practice-mental-math" },
    { "source": "/es/como-practicar-calculo-mental", "destination": "/how-to-practice-mental-math" },

    { "source": "/nl", "destination": "/" },
    { "source": "/es", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://www.googletagmanager.com; connect-src 'self' https://pwqklvedbydxmnhocaqp.supabase.co https://www.google-analytics.com https://region1.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:;"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        }
      ]
    }
  ]
}