---
import Layout from '../layouts/layout.astro';
---

<Layout title="404 — Page Not Found | Numfly">
  <style>
    /* Keep only the specific 404 styles, Layout handles the rest */
    .not-found-container {
      position: relative;
      text-align: center;
      animation: fadeUp .6s cubic-bezier(.4,0,.2,1) both;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 70vh;
    }
    .big-num {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(120px, 22vw, 200px);
      letter-spacing: 8px;
      line-height: 1;
      color: var(--accent);
      opacity: .15;
      user-select: none;
      animation: fadeUp .5s cubic-bezier(.4,0,.2,1) both;
    }
    .error-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 36px 40px;
      max-width: 400px;
      width: 100%;
      margin: -40px auto 0;
      position: relative;
    }
    .error-card::before {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 16px;
      background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(232,255,71,.05) 0%, transparent 60%);
      pointer-events: none;
    }
    .error-icon {
      font-size: 32px;
      margin-bottom: 16px;
      animation: wobble 2.4s ease-in-out infinite;
      display: block;
    }
    .error-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 28px;
      letter-spacing: 2px;
      margin-bottom: 10px;
      color: var(--text);
    }
    .error-sub {
      font-size: 12px;
      color: var(--muted);
      line-height: 1.7;
      margin-bottom: 28px;
    }
    .error-code {
      margin-top: 24px;
      font-size: 10px;
      color: var(--muted2);
      letter-spacing: 1.5px;
      text-transform: uppercase;
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes wobble {
      0%, 100% { transform: rotate(-4deg); }
      50%       { transform: rotate(4deg); }
    }
  </style>

  <div class="not-found-container">
    <div class="big-num">404</div>
    <div class="error-card">
      <span class="error-icon">🧮</span>
      <div class="error-title">Page Not Found</div>
      <p class="error-sub">Looks like this page doesn't add up.<br>It may have been moved or never existed.</p>
      <a class="btn btn-primary" href="/">Back to Numfly</a>
      <div class="error-code">Error 404 · Page not found</div>
    </div>
  </div>
</Layout>