---
export const prerender = true;

import Layout from '../../layouts/layout.astro';

// Import ALL your components
import MainMenu from '../../components/Mainmenu.astro';
import FriendsComponent from '../../components/Friends.astro';
import StatsComponent from '../../components/Stats.astro';
import LeaderboardComponent from '../../components/Leaderboard.astro';
import AchievementsComponent from '../../components/Achievements.astro';
import TipsComponent from '../../components/Tips.astro';
import CampaignComponent from '../../components/Campaign.astro';
import DailyComponent from '../../components/Daily.astro';
import LightningComponent from '../../components/Lightning.astro';
import SpeedComponent from '../../components/Speed.astro';
import PracticeComponent from '../../components/Practice.astro';

export function getStaticPaths() {
  return [
    // 🇳🇱 Dutch Routes
    { params: { lang: 'nl', route: undefined }, props: { page: 'home' } }, // Catches /nl
    { params: { lang: 'nl', route: 'vrienden' }, props: { page: 'friends' } }, // Catches /nl/vrienden
    { params: { lang: 'nl', route: 'statistieken' }, props: { page: 'stats' } },
    { params: { lang: 'nl', route: 'klassement' }, props: { page: 'leaderboard' } },
    { params: { lang: 'nl', route: 'prestaties' }, props: { page: 'achievements' } },
    { params: { lang: 'nl', route: 'tips' }, props: { page: 'tips' } },
    { params: { lang: 'nl', route: 'campagne' }, props: { page: 'campaign' } },
    { params: { lang: 'nl', route: 'dagelijks' }, props: { page: 'daily' } },
    { params: { lang: 'nl', route: 'bliksem' }, props: { page: 'lightning' } },
    { params: { lang: 'nl', route: 'snelheid' }, props: { page: 'speed' } },
    { params: { lang: 'nl', route: 'oefenen' }, props: { page: 'practice' } },
    { params: { lang: 'nl', route: '1v1' }, props: { page: '1v1' } },

    // 🇪🇸 Spanish Routes
    { params: { lang: 'es', route: undefined }, props: { page: 'home' } }, // Catches /es
    { params: { lang: 'es', route: 'amigos' }, props: { page: 'friends' } },
    { params: { lang: 'es', route: 'estadisticas' }, props: { page: 'stats' } },
    { params: { lang: 'es', route: 'clasificacion' }, props: { page: 'leaderboard' } },
    { params: { lang: 'es', route: 'logros' }, props: { page: 'achievements' } },
    { params: { lang: 'es', route: 'consejos' }, props: { page: 'tips' } },
    { params: { lang: 'es', route: 'campana' }, props: { page: 'campaign' } },
    { params: { lang: 'es', route: 'diario' }, props: { page: 'daily' } },
    { params: { lang: 'es', route: 'rayo' }, props: { page: 'lightning' } },
    { params: { lang: 'es', route: 'velocidad' }, props: { page: 'speed' } },
    { params: { lang: 'es', route: 'practica' }, props: { page: 'practice' } },
    { params: { lang: 'es', route: '1v1' }, props: { page: '1v1' } },
  ];
}

const { page } = Astro.props;
---

<Layout>
  {page === 'home' && <MainMenu />}
  {page === 'friends' && (
    <>
      <FriendsComponent />
      <SpeedComponent />
    </>
  )}
  {page === 'stats' && <StatsComponent />}
  {page === 'leaderboard' && (
    <>
      <LeaderboardComponent />
      <SpeedComponent />
    </>
  )}
  {page === 'achievements' && <AchievementsComponent />}
  {page === 'tips' && <TipsComponent />}
  {page === 'campaign' && <CampaignComponent />}
  {page === 'daily' && <DailyComponent />}
  {page === 'lightning' && <LightningComponent />}
  {page === 'speed' && <SpeedComponent />}
  {page === 'practice' && <PracticeComponent />}
  {page === '1v1' && <SpeedComponent />}
</Layout>