<script is:inline>
// ─── Reading bar ───────────────────────────────────────────────
const bar = document.getElementById('reading-bar');
window.addEventListener('scroll', () => {
  const d = document.documentElement;
  if (bar) bar.style.width = (d.scrollTop / (d.scrollHeight - d.clientHeight) * 100) + '%';
}, { passive: true });

// ─── Technique accordion ───────────────────────────────────────
window.tog = function(header) {
  const technique = header.closest('.technique');
  if (!technique) return;
  technique.classList.toggle('open');
  header.setAttribute('aria-expanded', technique.classList.contains('open') ? 'true' : 'false');
};

// ─── FAQ accordion ─────────────────────────────────────────────
window.faq = function(btn) {
  const item = btn.closest('.faq-item');
  if (!item) return;
  const was = item.classList.contains('open');
  document.querySelectorAll('.faq-item.open').forEach(el => el.classList.remove('open'));
  if (!was) item.classList.add('open');
};
</script>
