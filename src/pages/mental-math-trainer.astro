type LangCode = keyof typeof translations;
let currentLang: LangCode = 'en';

function setLang(lang: LangCode): void {
  currentLang = lang;
  try { localStorage.setItem('numfly_lang', lang); } catch(e) {}

  const buttons = document.querySelectorAll('.lang-btn');
  buttons.forEach(b => b.classList.remove('active'));
  const activeBtn = document.querySelector(`.lang-btn[onclick="setLang('${lang}')"]`);
  if (activeBtn) activeBtn.classList.add('active');

  document.querySelectorAll('[data-lang]').forEach(el => {
    const htmlEl = el as HTMLElement;
    htmlEl.classList.toggle('lang-active', htmlEl.dataset.lang === lang);
  });

  const t = translations[lang] as Record<string, string>;
  document.querySelectorAll('[data-lang-key]').forEach(el => {
    const htmlEl = el as HTMLElement;
    const key = htmlEl.dataset.langKey ?? '';
    if (t[key] !== undefined) htmlEl.innerHTML = t[key];
  });

  if (t.page_title) document.title = t.page_title;
  const metaDesc = document.querySelector('meta[name="description"]');
  if (metaDesc && t.page_description) metaDesc.setAttribute('content', t.page_description);
  document.documentElement.lang = lang;
}

// Detect saved language preference
try {
  const saved = localStorage.getItem('numfly_lang') as LangCode | null;
  if (saved && translations[saved]) setLang(saved);
  else setLang('en');
} catch(e) { setLang('en'); }
</script>
