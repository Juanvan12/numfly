  z-index: 1;
  max-width: 720px;
  margin: 0 auto;
  padding: 0 24px 60px;
}
.compete-cta {
  background: var(--surface);
  border: 1px solid var(--border2);
  border-radius: 16px;
  padding: 32px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 32px;
}
.compete-tag {
  font-family: 'DM Mono', monospace;
  font-size: 9px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 12px;
}
.compete-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(24px, 3.5vw, 32px);
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--text);
  line-height: 1.05;
  margin-bottom: 12px;
}
.compete-sub { font-size: 14px; color: var(--muted); margin-bottom: 20px; max-width: 380px; }
.compete-btns { display: flex; gap: 10px; flex-wrap: wrap; }
.btn-ghost {
  display: inline-flex;
  align-items: center;
  padding: 11px 20px;
  background: none;
  color: var(--muted);
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 1.5px;
  border: 1px solid var(--border2);
  text-transform: uppercase;
  text-decoration: none;
  border-radius: 6px;
  white-space: nowrap;
  transition: border-color .15s, color .15s;
}
.btn-ghost:hover { border-color: var(--accent); color: var(--accent); opacity: 1; }
.compete-right { flex-shrink: 0; }
.vs-card {
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 16px 20px;
  display: flex;
  align-items: center;
  gap: 16px;
  min-width: 200px;
}
.vs-player { display: flex; flex-direction: column; align-items: center; gap: 6px; flex: 1; }
.vs-name {
  font-family: 'DM Mono', monospace;
  font-size: 9px;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--muted2);
}
.vs-score {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 36px;
  letter-spacing: 1px;
  line-height: 1;
}
.vs-player.you .vs-score { color: var(--accent); }
.vs-player.opp .vs-score { color: var(--muted); }
.vs-bar { width: 100%; height: 3px; background: var(--border); border-radius: 2px; overflow: hidden; }
.vs-fill { height: 100%; border-radius: 2px; }
.you-fill { background: var(--accent); animation: youbar 1.8s ease-in-out infinite alternate; }
.opp-fill { background: var(--muted2); animation: oppbar 1.8s ease-in-out infinite alternate; }
@keyframes youbar { from { width: 56%; } to { width: 72%; } }
@keyframes oppbar { from { width: 44%; } to { width: 52%; } }
.vs-sep {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 14px;
  letter-spacing: 2px;
  color: var(--border2);
}

footer {
  padding: 28px 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 14px;
  max-width: 720px;
  margin: 0 auto;
}
.f-logo {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 18px;
  letter-spacing: 3px;
  color: var(--muted2);
  text-decoration: none;
}
.f-logo span { color: var(--muted); }
.f-links { display: flex; gap: 20px; }
.f-links a {
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--muted2);
  text-decoration: none;
  transition: color .15s;
}
.f-links a:hover { color: var(--muted); }
.f-copy { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--muted2); }

.reveal { opacity: 0; transform: translateY(14px); transition: opacity .5s ease, transform .5s ease; }
.reveal.visible { opacity: 1; transform: none; }

[data-lang] { display: none; }
[data-lang].lang-active { display: block; }
[data-lang-inline] { display: none; }
[data-lang-inline].lang-active { display: inline; }
