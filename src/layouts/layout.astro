---
import { ClientRouter } from 'astro:transitions';
import Sidebar from '../components/Sidebar.astro';
import Modals from '../components/Modals.astro';
import SocialScreens from '../components/SocialScreens.astro';

// ── SEO & Hreflang URL Generation ──
const { pathname } = Astro.url;

// Pages that have a back button — burger should be hidden on mobile for these
const noMenuPages = ['/campaign', '/lightning', '/speed', '/practice', '/daily',
  '/stats', '/achievements', '/friends', '/leaderboard', '/tips', '/1v1'];
const strippedPath = pathname.replace(/^\/(nl|es)/, '').replace(/\/$/, '') || '/';
const isBackButtonPage = noMenuPages.some(p => strippedPath === p);

// 1. Added ": string" to the path parameter
function getBasePage(path: string) {
  let p = path.replace(/\/$/, ""); 
  p = p.replace(/^\/(nl|es)/, "");
  if (p === "") p = "/";

  // 2. Added ": Record<string, string>" to tell TS this object maps strings to strings
  const reverseMap: Record<string, string> = {
    "/vrienden": "/friends", "/amigos": "/friends",
    "/statistieken": "/stats", "/estadisticas": "/stats",
    "/klassement": "/leaderboard", "/clasificacion": "/leaderboard",
    "/prestaties": "/achievements", "/logros": "/achievements",
    "/hoofdrekenen-oefenen": "/how-to-practice-mental-math",
    "/como-practicar-calculo-mental": "/how-to-practice-mental-math",
    "/campagne": "/campaign", "/campana": "/campaign",
    "/dagelijks": "/daily", "/diario": "/daily",
    "/bliksem": "/lightning", "/rayo": "/lightning",
    "/snelheid": "/speed", "/velocidad": "/speed",
    "/oefenen": "/practice", "/practica": "/practice",
    "/tips": "/tips", "/consejos": "/tips"
  };
  return reverseMap[p] || p;
}

const basePage = getBasePage(pathname);

// 3. Added ": Record<string, string>" to the translation maps
const enToNl: Record<string, string> = { "/friends":"/vrienden", "/stats":"/statistieken", "/leaderboard":"/klassement", "/achievements":"/prestaties", "/how-to-practice-mental-math":"/hoofdrekenen-oefenen", "/campaign":"/campagne", "/daily":"/dagelijks", "/lightning":"/bliksem", "/speed":"/snelheid", "/practice":"/oefenen", "/tips":"/tips" };
const enToEs: Record<string, string> = { "/friends":"/amigos", "/stats":"/estadisticas", "/leaderboard":"/clasificacion", "/achievements":"/logros", "/how-to-practice-mental-math":"/como-practicar-calculo-mental", "/campaign":"/campana", "/daily":"/diario", "/lightning":"/rayo", "/speed":"/velocidad", "/practice":"/practica", "/tips":"/consejos" };

const nlPath = enToNl[basePage] || basePage;
const esPath = enToEs[basePage] || basePage;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Numfly - Free Math Games & Mental Math Practice</title>

  <ClientRouter />
  
  <link rel="alternate" hreflang="x-default" href={`https://numfly.pro${basePage}`} />
  <link rel="alternate" hreflang="en" href={`https://numfly.pro${basePage}`} />
  <link rel="alternate" hreflang="nl" href={`https://numfly.pro/nl${nlPath}`} />
  <link rel="alternate" hreflang="es" href={`https://numfly.pro/es${esPath}`} />

  <link rel="icon" type="image/png" href="/favicon-32.png">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
  <link rel="preconnect" href="https://pwqklvedbydxmnhocaqp.supabase.co">
  <link rel="dns-prefetch" href="https://pwqklvedbydxmnhocaqp.supabase.co">
  <script defer src="https://cloud.umami.is/script.js" data-website-id="cd564c8c-72a1-4276-a04e-42ba9479d067"></script>

</head>
<body>
  <div class="grid-bg"></div>
  
  
    <button id="burger-fixed" onclick="openSidebar()" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  
  <div class="app">
    <Sidebar />
    <slot />
    
    <div class="xp-toast" id="xp-toast">+0 XP</div>
    <div class="err-toast" id="err-toast"></div>
    <div class="ach-toast" id="ach-toast">
      <div class="ach-toast-icon" id="ach-toast-icon">🏅</div>
      <div>
        <div class="ach-toast-text" data-i18n="ach_unlocked_label"></div>
        <div class="ach-toast-name" id="ach-toast-name"></div>
      </div>
    </div>

    <div class="modal-overlay titles-modal-overlay" id="modal-titles" onclick="if(event.target===this)closeTitlesModal()">
      <div class="titles-modal-box">
        <div class="titles-modal-header">
          <div class="titles-modal-title">🏅 <span data-i18n="titles_modal_title"></span></div>
          <button class="titles-modal-close" onclick="closeTitlesModal()">✕</button>
        </div>
        <div class="titles-modal-sub" id="titles-modal-sub"></div>
        <div class="titles-list" id="titles-list"></div>
      </div>
    </div>

    <div class="levelup-overlay" id="modal-levelup">
      <div class="levelup-box">
        <div class="levelup-fireworks">🎉</div>
        <div class="levelup-label" data-i18n="levelup_label"></div>
        <div class="levelup-num" id="lu-level">2</div>
        <div class="levelup-title-name" id="lu-title-name"></div>
        <div class="levelup-title-flavor" id="lu-title-flavor"></div>
        <button class="btn btn-primary" style="max-width:200px;margin:0 auto" onclick="closeLevelUp()" data-i18n="levelup_btn"></button>
      </div>
    </div>

    <div id="login-overlay" style="display:none;position:fixed;inset:0;background:rgba(8,8,14,.88);z-index:900;align-items:center;justify-content:center;flex-direction:column;gap:14px;">
      <span class="spinner" style="width:32px;height:32px;border-width:3px;"></span>
      <div style="font-family:'DM Mono',monospace;font-size:12px;color:var(--muted);letter-spacing:1px">Signing in…</div>
    </div>
    
    <SocialScreens />
    <Modals />
  </div>

  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2.39.3/dist/umd/supabase.js" defer></script>

  <!-- ── Numfly split scripts — load in dependency order ── -->
  <script src="/scripts/i18n.js" defer></script>       <!-- STRINGS, t(), setLang() -->
  <script src="/scripts/state.js" defer></script>       <!-- hs, stats, xp, GAME_CONFIG, audio -->
  <script src="/scripts/generator.js" defer></script>   <!-- RANGES, genProblem(), checkAns(), recordAnswer() -->
  <script src="/scripts/campaign.js" defer></script>    <!-- CAMPAIGN_LEVELS, campaign state & logic -->
  <script src="/scripts/navigation.js" defer></script>  <!-- showScreen(), clearGameTimers() -->
  <script src="/scripts/achievements.js" defer></script><!-- ACHIEVEMENTS, checkAchievements(), renderAchievements() -->
  <script src="/scripts/stats.js" defer></script>       <!-- renderStatsContent(), renderHSPanel() -->
  <script src="/scripts/tips.js" defer></script>        <!-- TIPS data, renderTipsList() -->
  <script src="/scripts/tip-practice.js" defer></script><!-- genTipProblem(), startTipPractice() -->
  <script src="/scripts/lightning.js" defer></script>   <!-- startLightning(), checkLightningAnswer() -->
  <script src="/scripts/speed.js" defer></script>       <!-- startSpeed(), checkSpeedAnswer(), endSpeed() -->
  <script src="/scripts/practice.js" defer></script>    <!-- startPractice(), checkPracticeAnswer() -->
  <script src="/scripts/auth.js" defer></script>        <!-- Supabase init, auth, login pipeline, sync -->
  <script src="/scripts/social.js" defer></script>      <!-- friends, leaderboard, group comp, H2H -->
  <script src="/scripts/daily.js" defer></script>       <!-- daily challenge, streak, seededRand() -->
  <script src="/scripts/challenges.js" defer></script>  <!-- challenge mode, speed overrides, 1v1 -->
  <script src="/scripts/main.js" defer></script>        <!-- GDPR, guest state, lang, astro:page-load -->
  
</body>
</html>