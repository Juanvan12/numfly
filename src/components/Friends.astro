<div id="screen-friends" class="screen">
  <a href="/" class="back-link" style="text-decoration: none;">← <span data-i18n="back"></span></a>
  
  <div class="social-hero">
    <div class="social-hero-title">👥 <span data-i18n="nav_friends"></span></div>
    <div class="social-hero-sub" data-i18n="friends_sub"></div>
  </div>
  
  <div style="position:relative;margin-bottom:16px;">
    <input class="search-input" id="friend-search-input" data-i18n-placeholder="friends_search_ph" maxlength="30" autocomplete="off" onkeydown="if(event.key==='Enter')searchUser()" style="width:100%;padding-right:52px;">
    <button onclick="searchUser()" style="position:absolute;right:0;top:0;bottom:0;padding:0 16px;background:var(--accent);border:none;border-radius:0 8px 8px 0;color:#000;font-family:'Bebas Neue',sans-serif;font-size:18px;cursor:pointer;">→</button>
  </div>
  
  <div id="friend-search-result" style="margin-bottom:14px;"></div>
  
  <div id="friends-pending-section" style="display:none">
    <div class="friend-req-section">
      <div class="friend-req-title">🔔 <span data-i18n="friends_requests_title"></span> <span id="friends-pending-count" class="friend-req-badge">0</span></div>
      <div id="friends-pending-list"></div>
    </div>
  </div>
  
  <div id="friends-challenges-section" style="display:none">
    <div class="friend-req-section">
      <div class="friend-req-title">⚔ <span data-i18n="challenge_pending_title"></span></div>
      <div id="friends-challenges-list"></div>
    </div>
  </div>
  
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;margin-top:20px;">
    <div class="ach-section-title" style="margin:0" data-i18n="friends_your"></div>
    <button onclick="openGroupCompModal()" id="group-comp-btn" style="display:none;padding:7px 14px;background:linear-gradient(135deg,rgba(192,132,252,.15),rgba(168,85,247,.1));border:1px solid rgba(192,132,252,.4);border-radius:20px;color:var(--purple);font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.5px;cursor:pointer;white-space:nowrap;flex-shrink:0;">🏆 <span data-i18n="comp_group_title"></span></button>
  </div>
  
  <div id="friends-list"><div style="font-family:'DM Mono',monospace;font-size:12px;color:var(--muted);padding:12px 0" data-i18n="friends_sign_in_msg"></div></div>
  
  <div id="friends-blocked-section" style="display:none;margin-top:20px;">
    <div class="ach-section-title" style="color:var(--error)">🚫 <span data-i18n="blocked_users"></span></div>
    <div id="friends-blocked-list"></div>
  </div>
  
  <div id="remove-friend-popup" style="display:none;position:fixed;inset:0;z-index:900;background:rgba(0,0,0,.75);align-items:center;justify-content:center;padding:20px;">
    <div style="background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:28px 24px;max-width:300px;width:100%;">
      <div style="font-family:'Bebas Neue',sans-serif;font-size:11px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;margin-bottom:10px" data-i18n="remove_friend_confirm"></div>
      <div style="font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:1px;margin-bottom:20px;color:var(--text)" id="remove-friend-name"></div>
      <div style="display:flex;flex-direction:column;gap:8px;">
        <button onclick="confirmRemoveFriend(false)" style="padding:11px 16px;border:1px solid var(--border2);background:transparent;color:var(--text);border-radius:8px;font-family:'DM Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:.5px;cursor:pointer;text-align:left;display:flex;align-items:center;gap:10px;"><span style="font-size:16px">👋</span> <span data-i18n="remove_friend"></span></button>
        <button onclick="confirmRemoveFriend(true)" style="padding:11px 16px;border:1px solid var(--border2);background:transparent;color:var(--text);border-radius:8px;font-family:'DM Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:.5px;cursor:pointer;text-align:left;display:flex;align-items:center;gap:10px;"><span style="font-size:16px">🚫</span> <span data-i18n="block_user"></span></button>
        <button onclick="closeRemoveFriendPopup()" style="padding:11px 16px;border:none;background:transparent;color:var(--muted);border-radius:8px;font-family:'DM Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:.5px;cursor:pointer;text-align:center;" data-i18n="cancel"></button>
      </div>
    </div>
  </div>
</div>
