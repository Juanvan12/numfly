<div id="screen-menu" class="screen active">
  <div class="mobile-header" style="align-items:center;justify-content:center;gap:10px;">
    <svg width="32" height="32" viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <circle cx="26" cy="26" r="25" fill="rgba(232,255,71,0.06)" stroke="rgba(232,255,71,0.18)" stroke-width="1"/>
      <path d="M8 11 L44 25 L19 31 Z" fill="#e8ff47"/>
      <path d="M19 31 L13 44 L25 34 Z" fill="#e8ff47" opacity="0.55"/>
      <path d="M19 31 L44 25" stroke="rgba(8,8,14,0.35)" stroke-width="1"/>
      <path d="M5 19 L12 21" stroke="#e8ff47" stroke-width="1.8" stroke-linecap="round" opacity="0.45"/>
      <path d="M4 26 L10 26" stroke="#e8ff47" stroke-width="1.4" stroke-linecap="round" opacity="0.28"/>
    </svg>
    <div style="font-family:'Bebas Neue',sans-serif;font-size:26px;letter-spacing:4px;line-height:1;color:var(--text);">NUM<span style="color:var(--accent)">FLY</span><span style="color:var(--accent)">.</span></div>
  </div>
  <div class="lang-bar" style="padding-left:58px;">
    <button class="lang-btn" onclick="setLang('en',this);updateSidebarLangBtns()">EN</button>
    <button class="lang-btn" onclick="setLang('nl',this);updateSidebarLangBtns()">NL</button>
    <button class="lang-btn" onclick="setLang('es',this);updateSidebarLangBtns()">ES</button>
  </div>
  <div class="numfly-logo">
    <svg width="52" height="52" viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <circle cx="26" cy="26" r="25" fill="rgba(232,255,71,0.06)" stroke="rgba(232,255,71,0.18)" stroke-width="1"/>
      <path d="M8 11 L44 25 L19 31 Z" fill="#e8ff47"/>
      <path d="M19 31 L13 44 L25 34 Z" fill="#e8ff47" opacity="0.55"/>
      <path d="M19 31 L44 25" stroke="rgba(8,8,14,0.35)" stroke-width="1"/>
      <path d="M5 19 L12 21" stroke="#e8ff47" stroke-width="1.8" stroke-linecap="round" opacity="0.45"/>
      <path d="M4 26 L10 26" stroke="#e8ff47" stroke-width="1.4" stroke-linecap="round" opacity="0.28"/>
    </svg>
    <div class="numfly-name">NUM<span class="fly">FLY</span><span class="dot">.</span></div>
  </div>
  <div class="tagline" data-i18n="tagline"></div>
  <div class="menu-nav">
    <button class="nav-btn" onclick="window.location.href=window.getLocalizedUrl('/tips')">
      <span class="nav-icon">💡</span><span data-i18n="nav_tips"></span>
    </button>
    <button class="nav-btn" id="nav-friends-btn" onclick="openSocial('friends')" style="position:relative">
      <span class="nav-icon">👥</span><span data-i18n="nav_friends"></span>
      <span id="nav-friends-badge" style="display:none;position:absolute;top:6px;right:6px;background:var(--error);color:#fff;font-family:'DM Mono',monospace;font-size:9px;font-weight:600;border-radius:8px;min-width:16px;height:16px;padding:0 4px;line-height:16px;text-align:center"></span>
    </button>
    <button class="nav-btn" onclick="openSocial('leaderboard')">
      <span class="nav-icon">🏆</span><span data-i18n="nav_leaderboard"></span>
    </button>
  </div>
  <div class="xp-panel" id="xp-panel" onclick="openTitlesModal()" style="cursor:pointer;" title="View Titles">
    <div class="xp-top">
      <div class="xp-left">
        <div class="xp-badge" id="xp-badge">🧮</div>
        <div class="xp-info">
          <div class="xp-level-label" data-i18n="xp_level_label"></div>
          <div class="xp-level-num" id="xp-level-num">1</div>
          <div class="xp-title-display" id="xp-title-display"></div>
        </div>
      </div>
      <div class="xp-right">
        <div class="xp-pts" id="xp-pts-display">0</div>
        <div class="xp-pts-label">XP</div>
      </div>
    </div>
    <div class="xp-bar-wrap"><div class="xp-bar-fill" id="xp-bar-fill" style="width:0%"></div></div>
    <div class="xp-bar-label"><span id="xp-bar-cur">0</span><span id="xp-bar-next">100 XP</span></div>
  </div>
<div class="daily-card-row">
  <div id="daily-card" class="daily-card daily-card-half" onclick="window.location.href=window.getLocalizedUrl('/turbo')" style="opacity:0;transition:opacity .2s;">
    <div class="daily-card-icon">🧮</div>
    <div class="daily-badge"><span class="daily-badge-dot"></span><span data-i18n="daily_badge"></span></div>
<div id="daily-streak-badge" class="streak-badge streak-badge-corner" onclick="event.stopPropagation();if(currentUser){this.style.opacity='.5';pullFromSupabase().then(()=>{renderStreakOnCard();updateDailyCard();this.style.opacity='1';});}" title="Tap to sync streak" style="cursor:pointer">
  <span class="streak-badge-fire">🔥</span>
  <span class="streak-badge-count" id="daily-streak-count">1</span>
</div>
    <div class="daily-title" data-i18n="daily_title"></div>
    <div class="daily-sub" data-i18n="daily_sub"></div>
    <div id="daily-your-time" class="daily-your-time" style="display:none"></div>
    <div id="daily-next-reset" style="display:none;font-family:'DM Mono',monospace;font-size:10px;color:var(--muted2);margin-top:4px;"></div>
  </div>

  <div id="circuit-card" class="daily-card daily-card-half" onclick="window.location.href=window.getLocalizedUrl('/circuit')" style="opacity:0;transition:opacity .2s;">
    <div class="daily-card-icon">🔀</div>
    <div class="daily-badge"><span class="daily-badge-dot"></span><span data-i18n="daily_badge"></span></div>
<div id="circuit-streak-badge" class="streak-badge streak-badge-corner" onclick="event.stopPropagation();if(typeof currentUser!=='undefined'&&currentUser){this.style.opacity='.5';pullFromSupabase().then(()=>{updateCircuitCard();this.style.opacity='1';});}" title="Tap to sync streak" style="cursor:pointer; display:none;">
  <span class="streak-badge-fire">🔥</span>
  <span class="streak-badge-count" id="circuit-streak-count">1</span>
</div>
    <div class="daily-title" data-i18n="circuit_card_title"></div>
    <div class="daily-sub" data-i18n="mode_circuit_desc"></div>
    <div id="circuit-your-time" class="daily-your-time" style="display:none"></div>
    <div id="circuit-next-reset" style="display:none;font-family:'DM Mono',monospace;font-size:10px;color:var(--muted2);margin-top:4px;"></div>
  </div>
</div>
