<!-- ══ CONFIRM RESET MODAL ════════════════════════════════════════════ -->
<div class="modal-overlay" id="modal-reset">
  <div class="modal-box">
    <div class="modal-title" data-i18n="reset_modal_title"></div>
    <div class="modal-desc" data-i18n="reset_modal_desc"></div>
    <div class="modal-btns">
      <button class="btn btn-secondary" style="margin-top:0" onclick="closeModal()" data-i18n="cancel"></button>
      <button class="btn btn-danger" style="margin-top:0" onclick="doReset()" data-i18n="reset_confirm"></button>
    </div>
  </div>
</div>


<!-- ══ USERNAME PICKER (Google new users) ═══════════════════════════ -->
<div class="username-picker-overlay" id="modal-username-picker">
  <div class="username-picker-box">
    <div class="username-picker-icon">👋</div>
    <div class="username-picker-title" data-i18n="pick_username_title"></div>
    <div class="username-picker-sub" data-i18n="pick_username_sub"></div>
    <div class="username-picker-error" id="pick-username-error"></div>
    <div class="auth-field" style="text-align:left">
      <label data-i18n="auth_username_label"></label>
      <input type="text" id="pick-username-input" maxlength="20" autocomplete="off" style="width:100%;background:var(--bg);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:'DM Mono',monospace;font-size:18px;padding:12px 14px;outline:none;transition:border-color .2s;text-align:center;" onkeydown="if(event.key==='Enter')doPickUsername()">
    </div>
    <button class="btn btn-primary" style="margin-top:12px" onclick="doPickUsername()" data-i18n="pick_username_save"></button>
  </div>
</div>

<!-- ══ AUTH MODAL ════════════════════════════════════════════════════ -->
<div class="auth-overlay" id="modal-auth">
  <div class="auth-box">
    <div class="auth-title" data-i18n="auth_join_title"></div>
    <div class="auth-sub" data-i18n="auth_join_sub"></div>
    <div class="auth-error" id="auth-error"></div>
    <div class="auth-tabs">
      <button class="auth-tab active" onclick="setAuthTab('register')" id="tab-register" data-i18n="auth_signup"></button>
      <button class="auth-tab" onclick="setAuthTab('login')" id="tab-login" data-i18n="auth_login"></button>
    </div>
    <div id="auth-register-fields">
      <form onsubmit="event.preventDefault();doRegister()" autocomplete="on">
        <div class="auth-field"><label data-i18n="auth_username_label"></label><input type="text" id="auth-username" data-i18n-placeholder="auth_username_ph" maxlength="20" autocomplete="username" name="username"></div>
        <div class="auth-field"><label data-i18n="auth_email_label"></label><input type="email" id="auth-email-reg" placeholder="you@example.com" autocomplete="email" name="email"></div>
        <div class="auth-field"><label data-i18n="auth_password_label"></label><div class="auth-pw-wrap"><input type="password" id="auth-password-reg" data-i18n-placeholder="auth_password_ph" autocomplete="new-password" name="password"><button type="button" class="auth-eye-btn" onclick="togglePwVis('auth-password-reg',this)" tabindex="-1"><svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></button></div></div>
        <div class="auth-field"><label data-i18n="auth_confirm_password_label"></label><div class="auth-pw-wrap"><input type="password" id="auth-password-confirm" data-i18n-placeholder="auth_confirm_password_ph" autocomplete="new-password" name="confirm-password"><button type="button" class="auth-eye-btn" onclick="togglePwVis('auth-password-confirm',this)" tabindex="-1"><svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></button></div></div>
        <button type="submit" class="btn btn-primary" style="margin-top:4px"><span id="auth-register-label" data-i18n="auth_create_btn"></span></button>
      </form>
    </div>
    <div id="auth-login-fields" style="display:none">
      <form onsubmit="event.preventDefault();doLogin()" autocomplete="on">
        <div class="auth-field"><label data-i18n="auth_email_or_username_label"></label><input type="text" id="auth-email-login" data-i18n-placeholder="auth_email_or_username_ph" autocomplete="username" autocapitalize="none" autocorrect="off" spellcheck="false" name="email" style="text-transform:none"></div>
        <div class="auth-field"><label data-i18n="auth_password_label"></label><div class="auth-pw-wrap"><input type="password" id="auth-password-login" data-i18n-placeholder="auth_password_login_ph" autocomplete="current-password" name="password"><button type="button" class="auth-eye-btn" onclick="togglePwVis('auth-password-login',this)" tabindex="-1"><svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></button></div></div>
        <button type="submit" class="btn btn-primary" id="auth-login-btn" style="margin-top:4px"><span id="auth-login-label" data-i18n="auth_login_btn"></span></button>
      </form>
      <button type="button" class="btn-guest" style="margin-top:6px" onclick="showForgotPassword()" data-i18n="auth_forgot_pw"></button>
    </div>
    <!-- Forgot password panel (shown inside auth modal) -->
    <div id="auth-forgot-fields" style="display:none">
      <div class="auth-error" id="forgot-pw-msg" style="color:var(--success);min-height:16px"></div>
      <div class="auth-field"><label data-i18n="auth_email_label"></label><input type="email" id="forgot-pw-email" placeholder="you@example.com" autocomplete="off" onkeydown="if(event.key==='Enter')doForgotPassword()"></div>
      <button class="btn btn-primary" id="forgot-pw-btn" style="margin-top:4px" onclick="doForgotPassword()" data-i18n="auth_reset_send"></button>
      <button type="button" class="btn-guest" style="margin-top:6px" onclick="showForgotPassword(false)" data-i18n="auth_back_to_login"></button>
    </div>
    <div class="auth-divider" data-i18n="auth_divider"></div>
    <button class="btn-google" onclick="doGoogleLogin()">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
      <span data-i18n="auth_google"></span>
    </button>
    <button class="btn-guest" onclick="closeAuthModal()" data-i18n="auth_guest"></button>
  </div>
</div>

<!-- ══ EDIT USERNAME MODAL ════════════════════════════════════════════ -->
<div class="edit-user-overlay" id="modal-edit-username">
  <div class="edit-user-box">
    <div style="font-family:'Bebas Neue',sans-serif;font-size:24px;letter-spacing:2px;margin-bottom:6px" data-i18n="edit_username_title"></div>
    <div style="font-family:'DM Mono',monospace;font-size:11px;color:var(--muted);margin-bottom:16px" id="edit-username-sub"></div>
    <div class="auth-error" id="edit-username-error"></div>
    <div class="auth-field"><label data-i18n="auth_username_label"></label><input type="text" id="edit-username-input" maxlength="20" autocomplete="off"></div>
    <button class="btn btn-primary" style="margin-top:8px" onclick="doEditUsername()" data-i18n="edit_username_save"></button>
    <button class="btn btn-secondary" style="margin-top:8px" onclick="closeEditUsername()" data-i18n="cancel"></button>
  </div>
</div>

<!-- ══ FRIENDS SCREEN ════════════════════════════════════════════════ -->
<div id="screen-friends" class="screen">
  <button class="back-link" onclick="showScreen('screen-menu')">← <span data-i18n="back"></span></button>
  <div class="social-hero">
    <div class="social-hero-title">👥 <span data-i18n="nav_friends"></span></div>
    <div class="social-hero-sub" data-i18n="friends_sub"></div>
  </div>
  <div style="position:relative;margin-bottom:16px;">
    <input class="search-input" id="friend-search-input" data-i18n-placeholder="friends_search_ph" maxlength="30" autocomplete="off" onkeydown="if(event.key==='Enter')searchUser()" style="width:100%;padding-right:52px;">
    <button onclick="searchUser()" style="position:absolute;right:0;top:0;bottom:0;padding:0 16px;background:var(--accent);border:none;border-radius:0 8px 8px 0;color:#000;font-family:'Bebas Neue',sans-serif;font-size:18px;cursor:pointer;">→</button>
  </div>
  <div id="friend-search-result" style="margin-bottom:14px;"></div>
  <!-- Friend requests (incoming) -->
  <div id="friends-pending-section" style="display:none">
    <div class="friend-req-section">
      <div class="friend-req-title">🔔 <span data-i18n="friends_requests_title"></span> <span id="friends-pending-count" class="friend-req-badge">0</span></div>
      <div id="friends-pending-list"></div>
    </div>
  </div>
  <div id="friends-challenges-section" style="display:none">
    <div class="friend-req-section">
      <div class="friend-req-title">⚔ <span data-i18n="challenge_pending_title"></span></div>
      <div id="friends-challenges-list"></div>
    </div>
  </div>
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;margin-top:20px;">
    <div class="ach-section-title" style="margin:0" data-i18n="friends_your"></div>
    <button onclick="openGroupCompModal()" id="group-comp-btn" style="display:none;padding:7px 14px;background:linear-gradient(135deg,rgba(192,132,252,.15),rgba(168,85,247,.1));border:1px solid rgba(192,132,252,.4);border-radius:20px;color:var(--purple);font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.5px;cursor:pointer;white-space:nowrap;flex-shrink:0;">🏆 <span data-i18n="comp_group_title"></span></button>
  </div>
  <div id="friends-list"><div style="font-family:'DM Mono',monospace;font-size:12px;color:var(--muted);padding:12px 0" data-i18n="friends_sign_in_msg"></div></div>
  <div id="friends-blocked-section" style="display:none;margin-top:20px;">
    <div class="ach-section-title" style="color:var(--error)">🚫 <span data-i18n="blocked_users"></span></div>
    <div id="friends-blocked-list"></div>
  </div>
  <!-- Inline remove friend confirmation -->
  <div id="remove-friend-popup" style="display:none;position:fixed;inset:0;z-index:900;background:rgba(0,0,0,.75);align-items:center;justify-content:center;padding:20px;">
    <div style="background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:28px 24px;max-width:300px;width:100%;">
      <div style="font-family:'Bebas Neue',sans-serif;font-size:11px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;margin-bottom:10px" data-i18n="remove_friend_confirm"></div>
      <div style="font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:1px;margin-bottom:20px;color:var(--text)" id="remove-friend-name"></div>
      <div style="display:flex;flex-direction:column;gap:8px;">
        <button onclick="confirmRemoveFriend(false)" style="padding:11px 16px;border:1px solid var(--border2);background:transparent;color:var(--text);border-radius:8px;font-family:'DM Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:.5px;cursor:pointer;text-align:left;display:flex;align-items:center;gap:10px;"><span style="font-size:16px">👋</span> <span data-i18n="remove_friend"></span></button>
        <button onclick="confirmRemoveFriend(true)" style="padding:11px 16px;border:1px solid var(--border2);background:transparent;color:var(--text);border-radius:8px;font-family:'DM Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:.5px;cursor:pointer;text-align:left;display:flex;align-items:center;gap:10px;"><span style="font-size:16px">🚫</span> <span data-i18n="block_user"></span></button>
        <button onclick="closeRemoveFriendPopup()" style="padding:11px 16px;border:none;background:transparent;color:var(--muted);border-radius:8px;font-family:'DM Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:.5px;cursor:pointer;text-align:center;" data-i18n="cancel"></button>
      </div>
    </div>
  </div>
</div>

<!-- ══ LEADERBOARD SCREEN ════════════════════════════════════════════ -->
<div id="screen-leaderboard" class="screen">
  <button class="back-link" onclick="showScreen('screen-menu')">← <span data-i18n="back"></span></button>
  <div class="social-hero">
    <div class="social-hero-title">🏆 <span data-i18n="nav_leaderboard"></span></div>
    <div class="social-hero-sub" data-i18n="leaderboard_sub"></div>
  </div>
  <!-- Scope toggle -->
  <div style="display:flex;background:var(--surface);border:1px solid var(--border);border-radius:8px;overflow:hidden;margin-bottom:14px;">
    <button id="lb-scope-friends" onclick="setLbScope('friends',this)" style="flex:1;padding:9px 0;border:none;background:var(--accent);color:#000;font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.5px;text-transform:uppercase;cursor:pointer;" data-i18n="dc_tab_friends"></button>
    <button id="lb-scope-global" onclick="setLbScope('global',this)" style="flex:1;padding:9px 0;border:none;background:transparent;color:var(--muted);font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.5px;text-transform:uppercase;cursor:pointer;" data-i18n="dc_tab_global"></button>
  </div>
  <!-- General -->
  <div style="margin-bottom:6px;font-family:'DM Mono',monospace;font-size:9px;color:var(--text);text-transform:uppercase;letter-spacing:1px;font-weight:600" data-i18n="lb_group_general"></div>
  <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px;">
    <button class="lb-cat-btn active" data-lbkey="xp" onclick="setLbTab('xp',this)">🏆 <span data-i18n="lb_tab_xp"></span></button>
    <button class="lb-cat-btn" data-lbkey="time" onclick="setLbTab('time',this)">⏱ <span data-i18n="lb_tab_time"></span></button>
    <button class="lb-cat-btn" data-lbkey="daily_streak" onclick="setLbTab('daily_streak',this)">🔥 <span data-i18n="lb_tab_streak"></span></button>
  </div>
  <!-- Lightning -->
  <div style="margin-bottom:6px;font-family:'DM Mono',monospace;font-size:9px;color:var(--text);text-transform:uppercase;letter-spacing:1px;font-weight:600">⚡ <span data-i18n="lb_group_lightning"></span></div>
  <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px;">
    <button class="lb-cat-btn" data-lbkey="lightning_easy" onclick="setLbTab('lightning_easy',this)" data-i18n="diff_easy"></button>
    <button class="lb-cat-btn" data-lbkey="lightning_medium" onclick="setLbTab('lightning_medium',this)" data-i18n="diff_medium"></button>
    <button class="lb-cat-btn" data-lbkey="lightning_hard" onclick="setLbTab('lightning_hard',this)" data-i18n="diff_hard"></button>
  </div>
  <!-- Speed -->
  <div style="margin-bottom:6px;font-family:'DM Mono',monospace;font-size:9px;color:var(--text);text-transform:uppercase;letter-spacing:1px;font-weight:600">🚀 <span data-i18n="lb_group_speed"></span></div>
  <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px;">
    <button class="lb-cat-btn" data-lbkey="speed_easy" onclick="setLbTab('speed_easy',this)" data-i18n="diff_easy"></button>
    <button class="lb-cat-btn" data-lbkey="speed_medium" onclick="setLbTab('speed_medium',this)" data-i18n="diff_medium"></button>
    <button class="lb-cat-btn" data-lbkey="speed_hard" onclick="setLbTab('speed_hard',this)" data-i18n="diff_hard"></button>
  </div>
  <div id="lb-content"><div style="font-family:'DM Mono',monospace;font-size:12px;color:var(--muted);padding:12px 0" data-i18n="lb_sign_in_msg"></div></div>
</div>

<!-- ══ CHALLENGE RESULT SCREEN ═══════════════════════════════════════ -->
<div id="screen-challenge-result" class="screen">
  <button class="back-link" onclick="showScreen('screen-menu')">← <span data-i18n="back"></span></button>
  <div class="challenge-banner">
    <div class="challenge-vs">⚔ <span data-i18n="challenge_title"></span></div>
    <div class="challenge-scores">
      <div class="challenge-score-box" id="cr-you-box">
        <div class="challenge-score-num" id="cr-your-score">—</div>
        <div class="challenge-score-name" id="cr-your-name">You</div>
      </div>
      <div style="font-family:'Bebas Neue',sans-serif;font-size:22px;color:var(--muted)">VS</div>
      <div class="challenge-score-box" id="cr-them-box">
        <div class="challenge-score-num" id="cr-their-score">—</div>
        <div class="challenge-score-name" id="cr-their-name">Friend</div>
      </div>
    </div>
    <div id="cr-verdict" style="font-family:'Bebas Neue',sans-serif;font-size:20px;margin-top:14px;letter-spacing:2px;"></div>
  </div>
  <div id="cr-share-section" style="display:none">
    <div class="challenge-link-box">
      <div class="challenge-link-url" id="cr-link">—</div>
      <button class="challenge-copy-btn" onclick="copyChallengeLink()" data-i18n="challenge_copy"></button>
    </div>
    <div style="font-family:'DM Mono',monospace;font-size:11px;color:var(--muted);margin-bottom:12px" data-i18n="challenge_link_sub"></div>
  </div>
  <button class="btn btn-primary" onclick="showScreen('screen-menu')" data-i18n="main_menu"></button>
</div>

<!-- ══ DAILY CHALLENGE GAME SCREEN ═══════════════════════════════════ -->
<div id="screen-daily-game" class="screen">
  <div style="display:flex;justify-content:flex-end;margin-bottom:10px;">
    <button class="back-link" style="margin-bottom:0" onclick="abandonDaily()">✕ <span data-i18n="main_menu"></span></button>
  </div>
  <div class="daily-hud">
    <div class="hud-item">
      <div class="hud-label" data-i18n="daily_progress_label"></div>
      <div class="hud-value accent"><span id="dc-current">1</span><span style="font-size:14px;color:var(--muted);font-family:'DM Mono',monospace">/10</span></div>
    </div>
    <div class="hud-item">
      <div class="hud-label" data-i18n="mode_daily"></div>
      <div class="hud-value" id="dc-date-display"></div>
    </div>
    <div class="hud-item">
      <div class="hud-label" data-i18n="hud_time"></div>
      <div class="hud-value daily-timer-live" id="dc-timer">0.0s</div>
    </div>
  </div>
  <div class="q-card"><div class="q-type" id="dc-op-type"></div><div class="q-text" id="dc-question">—</div></div>
  <div class="answer-row">
    <input type="text" inputmode="numeric" pattern="[0-9-]*" id="dc-answer" data-i18n-placeholder="answer_placeholder" autocomplete="off" autocorrect="off" autocapitalize="none" spellcheck="false">
    <button class="submit-btn" onmousedown="event.preventDefault()" onclick="checkDailyAnswer()">→</button>
  </div>
  <div class="feedback" id="dc-feedback"></div>
</div>

