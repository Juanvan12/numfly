<!-- ══ LIGHTNING SETUP ════════════════════════════════════════════════ -->
<div id="screen-lightning-setup" class="screen">
  <button class="back-link" onclick="window.location.href=typeof window.getLocalizedUrl==='function'?window.getLocalizedUrl('/'):'/'">← <span data-i18n="back"></span></button>
  <div class="panel-title">⚡ <span data-i18n="mode_lightning"></span></div>
  <div class="panel-sub" data-i18n="lightning_setup_sub"></div>
  <div class="field">
    <label data-i18n="diff_label"></label>
    <div class="diff-row" id="lightning-diff-row">
      <button class="diff-btn active" onclick="selectDiff('lightning','easy',this)" data-i18n="diff_easy"></button>
      <button class="diff-btn" onclick="selectDiff('lightning','medium',this)" data-i18n="diff_medium"></button>
      <button class="diff-btn" onclick="selectDiff('lightning','hard',this)" data-i18n="diff_hard"></button>
    </div>
  </div>
  <div class="field"><label data-i18n="lightning_count_label"></label><input type="number" id="l-count" value="5" min="2" max="20"></div>
  <div class="field"><label data-i18n="lightning_interval_label"></label><input type="number" id="l-interval" value="2" min="1" max="20"></div>
  <button class="btn btn-primary" onclick="startLightning()"><span data-i18n="start"></span> ⚡</button>
</div>

<!-- ══ LIGHTNING GAME ══════════════════════════════════════════════════ -->
<div id="screen-lightning-game" class="screen">
  <div style="display:flex;justify-content:flex-end;margin-bottom:10px;">
    <button class="back-link" style="margin-bottom:0" onclick="abandonLightning()">← <span data-i18n="back"></span></button>
  </div>
  <div class="hud">
    <div class="hud-item"><div class="hud-label" data-i18n="hud_streak"></div><div class="hud-value accent" id="l-score">0</div></div>
    <div class="hud-item"><div class="hud-label" data-i18n="hud_score"></div><div class="hud-value" id="l-hs-display">0</div></div>
    <div id="l-cumulative-display" style="display:none">0</div>
    <div class="hud-item"><div class="hud-label" data-i18n="hud_number"></div><div class="hud-value" id="l-progress">1/5</div></div>
  </div>
  <div class="progress-bar-wrap"><div class="progress-bar-fill" id="l-progress-bar" style="width:0%"></div></div>
  <div class="q-card" id="l-display"><div class="lightning-blank"></div></div>
  <div id="l-answer-section" style="display:none">
    <div class="answer-row">
      <input type="text" inputmode="numeric" pattern="[0-9-]*" id="l-answer" data-i18n-placeholder="sum_placeholder" autocomplete="off" autocorrect="off" autocapitalize="none" spellcheck="false">
      <button class="submit-btn" onmousedown="event.preventDefault()" onclick="checkLightningAnswer()" data-i18n="go"></button>
    </div>
    <div class="feedback" id="l-feedback"></div>
  </div>
</div>

<!-- ══ LIGHTNING RESULT ════════════════════════════════════════════════ -->
<div id="screen-lightning-result" class="screen">
  <div class="result-box">
    <div class="result-emoji" id="lr-emoji">🎉</div>
    <div class="result-title" id="lr-title"></div>
    <div class="result-score" id="lr-score">1</div>
    <div class="result-detail" id="lr-detail"></div>
  </div>
  <button class="btn btn-primary" onclick="lightningKeepGoing()"><span data-i18n="keep_going"></span> ⚡</button>
  <button class="btn btn-secondary" onclick="showScreen('screen-lightning-setup')" data-i18n="change_settings"></button>
  <button class="btn btn-secondary" onclick="lightning.abandoned=true;if(currentUser)scheduleSync();saveOpStats();saveGuestState();checkAchievements();flushPendingLevelUps();showScreen('screen-menu')" data-i18n="main_menu"></button>
</div>