<div id="screen-achievements" class="screen">
  <a href="/" class="back-link" style="text-decoration: none;">← <span data-i18n="back"></span></a>
  <div class="ach-hero">
    <div class="ach-hero-title" data-i18n="nav_achievements"></div>
    <div class="ach-hero-sub" data-i18n="ach_hero_sub"></div>
    <div class="ach-progress-summary">
      <div class="ach-progress-bar-wrap"><div class="ach-progress-bar-fill" id="ach-bar-fill" style="width:0%"></div></div>
      <div class="ach-progress-label" id="ach-progress-label">0 / 0</div>
    </div>
  </div>
  <div id="ach-medal-row" style="display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-bottom:18px;padding:14px 10px;background:var(--surface);border:1px solid var(--border);border-radius:12px;"></div>
  <div id="ach-content"></div>
</div>